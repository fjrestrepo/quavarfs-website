---
import InteriorLayout from '../layouts/InteriorLayout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import FeatureCard from '../components/FeatureCard.astro';
import SplitSection from '../components/SplitSection.astro';
import MetricBand from '../components/MetricBand.astro';
import CTA from '../components/CTA.astro';

const pageTitle = 'Contact | QUAVAR Facility Services';
const pageDescription =
  'Contact QUAVAR Facility Services to discuss facility priorities, service programs and proposal requirements for professional environments in Tampa Bay and Central Florida.';


const contactMetrics = [
  {
    value: '01',
    label: 'Direct Conversation',
    description: 'Start with facility context before defining scope or pricing.',
  },
  {
    value: '03',
    label: 'Contact Channels',
    description: 'Phone, email and office access for decision makers and facility teams.',
  },
  {
    value: '08',
    label: 'Service Areas',
    description: 'Tampa Bay, New Tampa, Westchase, Carrollwood and Central Florida.',
  },
  {
    value: '05',
    label: 'Intake Inputs',
    description: 'Facility type, priorities, schedule, access windows and standards.',
  },
];

const contactMethods = [
  {
    number: '01',
    label: 'Phone',
    value: '+1 (813) 600-7422',
    href: 'tel:+18136007422',
    description: 'Speak directly with QUAVAR about facility priorities, service expectations and next steps.',
  },
  {
    number: '02',
    label: 'Email',
    value: 'info@quavarfs.com',
    href: 'mailto:info@quavarfs.com',
    description: 'Share facility context, service requirements or proposal questions in writing.',
  },
  {
    number: '03',
    label: 'Office',
    value: 'Tampa, Florida',
    href: 'https://www.google.com/maps/search/?api=1&query=8875+Hidden+River+Parkway+Suite+300+Tampa+Florida+33637',
    description: 'QUAVAR supports professional environments across Tampa Bay and Central Florida.',
  },
];

const intakeItems = [
  'Facility type, location and approximate square footage',
  'Current service concerns, operating priorities or quality gaps',
  'Required frequency, preferred schedule and access windows',
  'High-visibility areas, stakeholder expectations and occupant needs',
  'Compliance, safety or site-specific requirements',
];

const conversationSteps = [
  {
    number: '01',
    title: 'Understand',
    description:
      'We begin with the operating context: how the facility functions, who uses it and where service standards matter most.',
  },
  {
    number: '02',
    title: 'Define',
    description:
      'We clarify scope, frequency, access, quality expectations and the service model required to support the environment responsibly.',
  },
  {
    number: '03',
    title: 'Recommend',
    description:
      'We structure a practical service recommendation aligned with the facility, the organization and the standards to be sustained.',
  },
];

const serviceAreas = [
  'Tampa',
  'New Tampa',
  'North Tampa',
  'Westchase',
  'Carrollwood',
  'Citrus Park',
  'Town n Country',
  'Central Florida',
];
---

<InteriorLayout title={pageTitle} description={pageDescription}>
  <section class="contact-page">
    <section class="contact-hero" aria-labelledby="contact-title">
      <div class="container contact-hero__grid">
        <div class="contact-hero__content">
          <p class="eyebrow">Contact QUAVAR</p>
          <h1 id="contact-title">Let us understand the environment first.</h1>
          <p>
            Speak with QUAVAR about your facility, operating priorities and the service standards required to support a professional environment.
          </p>
          <div class="contact-hero__actions" aria-label="Primary contact actions">
            <a class="button button-primary" href="mailto:info@quavarfs.com" onclick="window.trackQuavarEvent?.('email_click', { link_text: 'Start a Conversation', link_url: 'mailto:info@quavarfs.com', event_context: 'contact_hero' })">Start a Conversation</a>
            <a class="button button-secondary" href="tel:+18136007422" onclick="window.trackQuavarEvent?.('phone_click', { link_text: 'Call QUAVAR', link_url: 'tel:+18136007422', event_context: 'contact_hero' })">Call QUAVAR</a>
          </div>
        </div>

        <aside class="contact-hero__panel" aria-label="QUAVAR primary contact information">
          <div class="contact-hero__panel-rule" aria-hidden="true"></div>
          <p>QUAVAR Facility Services</p>
          <address>
            8875 Hidden River Parkway<br />
            Suite 300<br />
            Tampa, Florida 33637
          </address>
          <a href="mailto:info@quavarfs.com" onclick="window.trackQuavarEvent?.('email_click', { link_text: 'info@quavarfs.com', link_url: 'mailto:info@quavarfs.com', event_context: 'form_intro' })">info@quavarfs.com</a>
        </aside>
      </div>
    </section>

    <SplitSection
      eyebrow="Facility Conversation"
      title="Professional service begins with a clear operating conversation."
      description="A meaningful recommendation requires more than a list of tasks. It begins with understanding the environment, the people who use it and the standards your organization needs to maintain."
      image="/img/architecture/corporate-lobby.webp"
      alt="Modern corporate lobby representing a professional facility environment"
      imagePosition="right"
      theme="soft"
      actions={[
        { label: 'Email QUAVAR', href: 'mailto:info@quavarfs.com', variant: 'primary' },
        { label: 'View Services', href: '/services', variant: 'secondary' },
      ]}
    />


    <MetricBand
      eyebrow="Decision Maker Access"
      title="A more structured way to begin the facility conversation."
      description="The first step is not a generic quote. It is a clear discussion about the facility, the operating standard and the service model required to support it."
      variant="dark"
      items={contactMetrics}
    />

    <section id="reach-quavar" class="contact-methods section" aria-labelledby="contact-methods-title">
      <div class="container">
        <SectionHeader
          eyebrow="Reach QUAVAR"
          title="Direct access for facility decision makers."
          description="For service conversations, facility reviews or proposal discussions, contact QUAVAR directly."
          id="contact-methods-title"
        />

        <div class="contact-methods__grid">
          {
            contactMethods.map((method) => (
              <FeatureCard
                number={method.number}
                eyebrow={method.label}
                title={method.value}
                description={method.description}
                href={method.href}
                linkLabel={method.label === 'Office' ? 'View Location' : 'Contact'}
                variant="panel"
              />
            ))
          }
        </div>
      </div>
    </section>

    <section class="proposal-intake section" aria-labelledby="proposal-intake-title">
      <div class="container proposal-intake__grid">
        <div class="proposal-intake__content">
          <SectionHeader
            eyebrow="Proposal Intake"
            title="A better proposal starts with better context."
            description="QUAVAR structures recommendations around the facility itself: how it is used, where service quality is most visible and what standards must be sustained over time."
            theme="dark"
            id="proposal-intake-title"
          />
        </div>

        <div class="intake-panel">
          <p>Helpful details to include</p>
          <ul>
            {intakeItems.map((item) => <li>{item}</li>)}
          </ul>
        </div>
      </div>
    </section>

    <section class="conversation-process section" aria-labelledby="conversation-process-title">
      <div class="container">
        <SectionHeader
          eyebrow="Service Conversation"
          title="From initial discussion to structured recommendation."
          description="Our process is designed to create clarity before work begins and alignment before a service program is proposed."
          id="conversation-process-title"
        />

        <div class="conversation-process__grid">
          {
            conversationSteps.map((step) => (
              <FeatureCard
                number={step.number}
                title={step.title}
                description={step.description}
                variant="compact"
              />
            ))
          }
        </div>
      </div>
    </section>

    <section class="contact-form-section section" aria-labelledby="contact-form-title">
      <div class="container contact-form-section__grid">
        <div class="form-intro">
          <SectionHeader
            eyebrow="Message"
            title="Send a project note."
            description="Share the basic context of your facility and service requirements. A concise note is enough to begin the conversation."
            id="contact-form-title"
          />

          <div class="form-note" aria-label="Direct contact option">
            <span>Prefer direct email?</span>
            <a href="mailto:info@quavarfs.com" onclick="window.trackQuavarEvent?.('email_click', { link_text: 'info@quavarfs.com', link_url: 'mailto:info@quavarfs.com', event_context: 'form_intro' })">info@quavarfs.com</a>
          </div>
        </div>

        <form class="contact-form" action="mailto:info@quavarfs.com" method="post" enctype="text/plain" onsubmit="window.trackQuavarEvent?.('contact_form_attempt', { form_name: 'contact_form', form_action: 'mailto', event_context: 'contact_page' })">
          <div class="field-row">
            <label>
              <span>Name</span>
              <input type="text" name="name" autocomplete="name" required />
            </label>

            <label>
              <span>Email</span>
              <input type="email" name="email" autocomplete="email" required />
            </label>
          </div>

          <div class="field-row">
            <label>
              <span>Phone</span>
              <input type="tel" name="phone" autocomplete="tel" />
            </label>

            <label>
              <span>Facility Type</span>
              <select name="facility_type" required>
                <option value="">Select one</option>
                <option value="Healthcare">Healthcare</option>
                <option value="Commercial">Commercial</option>
                <option value="Industrial">Industrial</option>
                <option value="Education">Education</option>
                <option value="Hospitality">Hospitality</option>
                <option value="Retail">Retail</option>
                <option value="Other">Other</option>
              </select>
            </label>
          </div>

          <label>
            <span>Message</span>
            <textarea name="message" rows="7" required></textarea>
          </label>

          <div class="form-footer">
            <button type="submit" onclick="window.trackQuavarEvent?.('contact_form_attempt', { form_name: 'contact_form', form_action: 'mailto', event_context: 'contact_form_button' })">Send Message</button>
            <a href="mailto:info@quavarfs.com" onclick="window.trackQuavarEvent?.('email_click', { link_text: 'Email directly instead', link_url: 'mailto:info@quavarfs.com', event_context: 'contact_form_footer' })">Email directly instead</a>
          </div>
        </form>
      </div>
    </section>

    <section class="response-standard section" aria-labelledby="response-standard-title">
      <div class="container response-standard__grid">
        <div>
          <p class="section-label section-label--dark">QUAVAR Standard</p>
          <h2 id="response-standard-title">Clear communication. Practical recommendations. Professional follow-through.</h2>
        </div>

        <p>
          Every facility conversation should lead to clarity. Our role is to understand the operating environment, define the right service expectations and support decision makers with a disciplined path forward.
        </p>
      </div>
    </section>

    <section class="service-area section" aria-labelledby="service-area-title">
      <div class="container service-area__grid">
        <SectionHeader
          eyebrow="Service Area"
          title="Built for Tampa Bay and Central Florida."
          description="QUAVAR supports professional facilities in the region with a corporate, disciplined and facility-centered service model."
          id="service-area-title"
        />

        <ul class="service-area__list" aria-label="QUAVAR service areas">
          {serviceAreas.map((area) => <li>{area}</li>)}
        </ul>
      </div>
    </section>

    <CTA
      eyebrow="Next Step"
      title="Ready to discuss your facility?"
      description="Tell us about your environment, your expectations and the service framework you need QUAVAR to support."
      primaryLabel="Contact QUAVAR"
      primaryHref="/contact/#reach-quavar"
      secondaryLabel="+1 (813) 600-7422"
      secondaryHref="tel:+18136007422"
      variant="compact"
    />
    <section id="work-with-us" class="work-with-us section" aria-labelledby="work-with-us-title">
      <div class="container work-with-us__grid">
        <div class="work-with-us__content">
          <p class="eyebrow">Work With Us</p>
          <h2 id="work-with-us-title">Build your career with a team committed to operational excellence.</h2>
          <p>
            At QUAVAR, outstanding facilities begin with outstanding people. We are interested in connecting with professionals who share our commitment to quality, reliability and service excellence across professional environments.
          </p>
          <div class="work-with-us__actions">
            <a class="button button-primary" href="mailto:info@quavarfs.com?subject=Work%20With%20QUAVAR" onclick="window.trackQuavarEvent?.('work_with_us_click', { link_text: 'Submit Your Information', link_url: 'mailto:info@quavarfs.com?subject=Work%20With%20QUAVAR', event_context: 'work_with_us_primary' })">Submit Your Information</a>
            <a class="button button-secondary" href="mailto:info@quavarfs.com?subject=Work%20With%20QUAVAR" onclick="window.trackQuavarEvent?.('work_with_us_click', { link_text: 'Email QUAVAR', link_url: 'mailto:info@quavarfs.com?subject=Work%20With%20QUAVAR', event_context: 'work_with_us_secondary' })">Email QUAVAR</a>
          </div>
        </div>

        <aside class="work-with-us__panel" aria-label="Professional opportunities with QUAVAR">
          <span>Areas of Interest</span>
          <ul>
            <li>Field operations and service delivery</li>
            <li>Site supervision and quality assurance</li>
            <li>Specialty floor, carpet and facility care</li>
            <li>Administrative and client support roles</li>
          </ul>
          <p>
            Please include your name, contact information, area of interest and a brief summary of your experience. Resume or LinkedIn links are welcome.
          </p>
        </aside>
      </div>
    </section>


  </section>
</InteriorLayout>

<style>
  .contact-page {
    background: var(--color-white);
  }

  .contact-hero {
    position: relative;
    overflow: hidden;
    padding: clamp(112px, 14vw, 176px) 0 clamp(88px, 10vw, 132px);
    background:
      linear-gradient(90deg, rgba(0, 30, 61, 0.92), rgba(0, 30, 61, 0.72)),
      url('/img/architecture/modern-atrium.webp') center / cover;
  }

  .contact-hero::after {
    content: '';
    position: absolute;
    right: clamp(32px, 7vw, 96px);
    bottom: clamp(32px, 7vw, 96px);
    width: clamp(84px, 10vw, 144px);
    height: clamp(84px, 10vw, 144px);
    border-right: 1px solid rgba(255, 255, 255, 0.36);
    border-bottom: 1px solid rgba(255, 255, 255, 0.36);
    pointer-events: none;
  }

  .contact-hero__grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(300px, 380px);
    gap: clamp(48px, 8vw, 104px);
    align-items: end;
  }

  .contact-hero__content {
    max-width: 820px;
  }

  .contact-hero .eyebrow {
    color: var(--color-teal);
  }

  .contact-hero h1 {
    max-width: 820px;
    margin-top: 24px;
    color: var(--color-white);
  }

  .contact-hero__content > p:not(.eyebrow) {
    max-width: 640px;
    margin-top: 28px;
    color: rgba(255, 255, 255, 0.78);
    font-size: clamp(1.125rem, 1.6vw, 1.375rem);
    line-height: 1.62;
  }

  .contact-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    margin-top: 40px;
  }

  .contact-hero__actions .button-primary {
    background: var(--color-white);
    color: var(--color-navy);
  }

  .contact-hero__actions .button-primary:hover {
    background: var(--color-teal);
    color: var(--color-white);
  }

  .contact-hero__actions .button-secondary {
    color: var(--color-white);
    border-color: rgba(255, 255, 255, 0.34);
  }

  .contact-hero__actions .button-secondary:hover {
    color: var(--color-teal);
    border-color: var(--color-teal);
  }

  .contact-hero__panel {
    position: relative;
    padding: 40px;
    color: var(--color-white);
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.16);
    backdrop-filter: blur(16px);
  }

  .contact-hero__panel-rule {
    width: 56px;
    height: 2px;
    margin-bottom: 28px;
    background: var(--color-teal);
  }

  .contact-hero__panel p {
    margin: 0 0 20px;
    color: var(--color-white);
    font-family: var(--font-heading);
    font-size: 0.875rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    line-height: 1.35;
    text-transform: uppercase;
  }

  .contact-hero__panel address {
    color: rgba(255, 255, 255, 0.78);
    font-style: normal;
    line-height: 1.8;
  }

  .contact-hero__panel a {
    display: inline-flex;
    margin-top: 28px;
    color: var(--color-white);
    font-weight: 700;
    transition: color var(--transition-fast);
  }

  .contact-hero__panel a:hover,
  .contact-hero__panel a:focus-visible {
    color: var(--color-teal);
  }

  .contact-methods__grid,
  .conversation-process__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 24px;
    margin-top: 56px;
  }

  .proposal-intake {
    background: var(--color-navy);
  }

  .proposal-intake__grid {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(340px, 0.8fr);
    gap: clamp(48px, 7vw, 96px);
    align-items: start;
  }

  .proposal-intake :global(.section-header__title),
  .proposal-intake :global(.section-header__description) {
    color: var(--color-white);
  }

  .proposal-intake :global(.section-header__description) {
    opacity: 0.78;
  }

  .intake-panel {
    padding: 48px;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.14);
  }

  .intake-panel p {
    margin: 0 0 28px;
    color: var(--color-white);
    font-family: var(--font-heading);
    font-size: 0.875rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .intake-panel ul {
    display: grid;
    gap: 18px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .intake-panel li {
    position: relative;
    padding-left: 28px;
    color: rgba(255, 255, 255, 0.78);
    line-height: 1.62;
  }

  .intake-panel li::before {
    content: '';
    position: absolute;
    top: 0.74em;
    left: 0;
    width: 8px;
    height: 8px;
    background: var(--color-teal);
  }

  .contact-form-section {
    background: var(--color-off-white);
  }

  .contact-form-section__grid {
    display: grid;
    grid-template-columns: minmax(0, 0.8fr) minmax(0, 1.15fr);
    gap: clamp(48px, 7vw, 96px);
    align-items: start;
  }

  .form-note {
    display: grid;
    gap: 8px;
    margin-top: 48px;
    padding-top: 32px;
    border-top: 1px solid var(--color-border);
  }

  .form-note span {
    color: var(--color-slate);
    font-size: 0.875rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .form-note a {
    color: var(--color-navy);
    font-family: var(--font-heading);
    font-size: clamp(1.375rem, 2vw, 1.75rem);
    font-weight: 600;
    letter-spacing: -0.025em;
    transition: color var(--transition-fast);
  }

  .form-note a:hover,
  .form-note a:focus-visible {
    color: var(--color-teal);
  }

  .contact-form {
    display: grid;
    gap: 24px;
    padding: clamp(32px, 5vw, 56px);
    background: var(--color-white);
    border: 1px solid var(--color-border);
    box-shadow: var(--shadow-card);
  }

  .field-row {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 20px;
  }

  .contact-form label {
    display: grid;
    gap: 10px;
  }

  .contact-form label > span {
    color: var(--color-navy);
    font-size: 0.8125rem;
    font-weight: 700;
    letter-spacing: 0.09em;
    text-transform: uppercase;
  }

  .contact-form input,
  .contact-form select,
  .contact-form textarea {
    width: 100%;
    min-height: 54px;
    padding: 14px 16px;
    color: var(--color-navy);
    background: var(--color-white);
    border: 1px solid rgba(0, 30, 61, 0.18);
    border-radius: 0;
    outline: none;
    transition:
      border-color var(--transition-fast),
      box-shadow var(--transition-fast);
  }

  .contact-form textarea {
    resize: vertical;
  }

  .contact-form input:focus,
  .contact-form select:focus,
  .contact-form textarea:focus {
    border-color: var(--color-teal);
    box-shadow: 0 0 0 4px rgba(0, 168, 168, 0.12);
  }

  .form-footer {
    display: flex;
    flex-wrap: wrap;
    gap: 20px;
    align-items: center;
    justify-content: space-between;
    margin-top: 8px;
  }

  .form-footer button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 52px;
    padding: 0 28px;
    color: var(--color-white);
    background: var(--color-navy);
    border-radius: var(--radius-pill);
    font-size: 0.8125rem;
    font-weight: 700;
    letter-spacing: var(--letter-button);
    text-transform: uppercase;
    transition:
      background var(--transition-fast),
      transform var(--transition-fast),
      box-shadow var(--transition-fast);
  }

  .form-footer button:hover,
  .form-footer button:focus-visible {
    background: var(--color-teal);
    box-shadow: 0 14px 32px rgba(0, 168, 168, 0.18);
    transform: translateY(-1px);
  }

  .form-footer a {
    color: var(--color-navy);
    font-weight: 700;
    transition: color var(--transition-fast);
  }

  .form-footer a:hover,
  .form-footer a:focus-visible {
    color: var(--color-teal);
  }

  .response-standard {
    background: var(--color-navy);
  }

  .response-standard__grid {
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) minmax(0, 0.85fr);
    gap: clamp(48px, 7vw, 96px);
    align-items: end;
  }

  .response-standard h2 {
    max-width: 780px;
    color: var(--color-white);
  }

  .response-standard p:not(.section-label) {
    max-width: 560px;
    color: rgba(255, 255, 255, 0.76);
    font-size: clamp(1.125rem, 1.4vw, 1.25rem);
    line-height: 1.68;
  }

  .service-area__grid {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1fr);
    gap: clamp(48px, 7vw, 96px);
    align-items: start;
  }

  .service-area__list {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1px;
    margin: 0;
    padding: 0;
    list-style: none;
    background: var(--color-border);
    border: 1px solid var(--color-border);
  }

  .service-area__list li {
    padding: 24px;
    color: var(--color-navy);
    background: var(--color-white);
    font-weight: 700;
  }


  .work-with-us {
    position: relative;
    overflow: hidden;
    background:
      linear-gradient(135deg, rgba(0, 30, 61, 0.96), rgba(0, 30, 61, 0.84)),
      url('/img/operations/supervisor-tablet.webp') center / cover;
    color: var(--color-white);
  }

  .work-with-us::after {
    content: '';
    position: absolute;
    inset: auto clamp(24px, 6vw, 88px) clamp(24px, 6vw, 88px) auto;
    width: clamp(76px, 9vw, 132px);
    height: clamp(76px, 9vw, 132px);
    border-right: 1px solid rgba(255, 255, 255, 0.34);
    border-bottom: 1px solid rgba(255, 255, 255, 0.34);
    pointer-events: none;
  }

  .work-with-us__grid {
