---
interface MetricItem {
  value: string;
  label: string;
  description?: string;
}

interface Props {
  eyebrow?: string;
  title?: string;
  description?: string;
  items: MetricItem[];
  variant?: 'light' | 'dark' | 'panel';
}

const {
  eyebrow,
  title,
  description,
  items,
  variant = 'light',
} = Astro.props;

const classes = ['qv-metric-band', `qv-metric-band--${variant}`].join(' ');
---

<section class={classes} aria-label={title || eyebrow || 'QUAVAR performance metrics'}>
  <div class="container qv-metric-band__inner">
    {(eyebrow || title || description) && (
      <div class="qv-metric-band__header">
        {eyebrow && <p class="qv-metric-band__eyebrow">{eyebrow}</p>}
        {title && <h2>{title}</h2>}
        {description && <p>{description}</p>}
      </div>
    )}

    <div class="qv-metric-band__grid">
      {items.map((item) => (
        <article class="qv-metric-band__item">
          <strong>{item.value}</strong>
          <span>{item.label}</span>
          {item.description && <p>{item.description}</p>}
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .qv-metric-band {
    position: relative;
    overflow: hidden;
    padding: clamp(88px, 9vw, 132px) 0;
  }

  .qv-metric-band__inner {
    position: relative;
    z-index: 1;
  }

  .qv-metric-band--light {
    background: var(--color-white);
  }

  .qv-metric-band--panel {
    padding: var(--space-8);
    background: var(--color-off-white);
    border: 1px solid var(--color-border);
  }

  .qv-metric-band--dark {
    color: var(--color-white);
    background:
      radial-gradient(circle at 8% 20%, rgba(0, 168, 168, 0.26), transparent 34%),
      linear-gradient(135deg, rgba(255, 255, 255, 0.08), rgba(0, 168, 168, 0.04)),
      var(--color-navy);
  }

  .qv-metric-band--dark::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.055) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.055) 1px, transparent 1px);
    background-size: 96px 96px;
    mask-image: linear-gradient(90deg, rgba(0,0,0,0.08), rgba(0,0,0,0.8), rgba(0,0,0,0.08));
    pointer-events: none;
  }

  .qv-metric-band__header {
    max-width: 820px;
    margin-bottom: clamp(48px, 6vw, 80px);
  }

  .qv-metric-band__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    margin: 0 0 var(--space-3);
    color: var(--color-teal);
    font-family: var(--font-heading);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: var(--letter-eyebrow);
    line-height: 1.4;
    text-transform: uppercase;
  }

  .qv-metric-band__eyebrow::before {
    content: "";
    width: 32px;
    height: 2px;
    background: currentColor;
  }

  .qv-metric-band h2 {
    margin: 0;
    color: inherit;
  }

  .qv-metric-band__header > p:not(.qv-metric-band__eyebrow) {
    max-width: 680px;
    margin-top: var(--space-3);
    color: var(--color-slate);
    font-size: var(--font-size-body-lg);
    line-height: 1.58;
  }

  .qv-metric-band--dark .qv-metric-band__header > p:not(.qv-metric-band__eyebrow) {
    color: rgba(255, 255, 255, 0.76);
  }

  .qv-metric-band__grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    border-top: 1px solid rgba(0, 30, 61, 0.12);
    border-left: 1px solid rgba(0, 30, 61, 0.12);
    box-shadow: 0 28px 80px rgba(0, 0, 0, 0.12);
  }

  .qv-metric-band--dark .qv-metric-band__grid {
    border-color: rgba(255, 255, 255, 0.16);
  }

  .qv-metric-band__item {
    min-height: 230px;
    padding: clamp(32px, 4vw, 48px);
    border-right: 1px solid rgba(0, 30, 61, 0.12);
    border-bottom: 1px solid rgba(0, 30, 61, 0.12);
    background: rgba(255, 255, 255, 0.54);
  }

  .qv-metric-band--dark .qv-metric-band__item {
    background: rgba(255, 255, 255, 0.055);
    border-color: rgba(255, 255, 255, 0.16);
  }

  .qv-metric-band__item strong {
    display: block;
    color: var(--color-navy);
    font-family: var(--font-heading);
    font-size: clamp(2.5rem, 5vw, 4.25rem);
    font-weight: 600;
    letter-spacing: -0.055em;
    line-height: 0.95;
  }

  .qv-metric-band--dark .qv-metric-band__item strong {
    color: var(--color-white);
  }

  .qv-metric-band__item span {
    display: block;
    margin-top: var(--space-3);
    color: var(--color-navy);
    font-family: var(--font-heading);
    font-size: 0.8125rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    line-height: 1.45;
    text-transform: uppercase;
  }

  .qv-metric-band--dark .qv-metric-band__item span {
    color: var(--color-teal);
  }

  .qv-metric-band__item p {
    margin-top: var(--space-2);
    color: var(--color-slate);
    font-size: 0.95rem;
    line-height: 1.62;
  }

  .qv-metric-band--dark .qv-metric-band__item p {
    color: rgba(255, 255, 255, 0.72);
  }

  @media (max-width: 1024px) {
    .qv-metric-band__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .qv-metric-band {
      padding: 72px 0;
    }

    .qv-metric-band--panel {
      padding: var(--space-5) var(--space-4);
    }

    .qv-metric-band__header {
      margin-bottom: var(--space-5);
    }

    .qv-metric-band__grid {
      grid-template-columns: 1fr;
    }

    .qv-metric-band__item {
      min-height: auto;
      padding: var(--space-4);
    }
  }
</style>
