---
const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";

const navItems = [
  { label: "Services", href: "/services" },
  { label: "Industries", href: "/industries" },
  { label: "About", href: "/about" },
  { label: "Contact", href: "/contact" },
];

const isActive = (href: string) => {
  if (href === "/") return currentPath === "/";
  return currentPath === href || currentPath.startsWith(`${href}/`);
};
---

<header class="site-header" data-site-header>
  <div class="container site-header__inner">
    <a class="site-header__logo" href="/" aria-label="QUAVAR Facility Services Home">
      <img
        src="/img/brand/quavar-logo-lockup.png"
        alt="QUAVAR Facility Services"
        width="220"
        height="58"
      />
    </a>

    <nav class="site-header__nav" aria-label="Primary navigation">
      <ul>
        {navItems.map((item) => (
          <li>
            <a
              href={item.href}
              class:list={[{ "is-active": isActive(item.href) }]}
              aria-current={isActive(item.href) ? "page" : undefined}
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <a class="site-header__cta" href="/contact/#reach-quavar">Request a Proposal</a>

    <button
      class="site-header__menu-button"
      type="button"
      aria-label="Open navigation menu"
      aria-expanded="false"
      aria-controls="site-mobile-nav"
      data-menu-button
    >
      <span></span>
      <span></span>
    </button>
  </div>

  <div class="site-header__mobile" id="site-mobile-nav" data-mobile-nav hidden>
    <nav class="container" aria-label="Mobile navigation">
      <ul>
        {navItems.map((item) => (
          <li>
            <a
              href={item.href}
              class:list={[{ "is-active": isActive(item.href) }]}
              aria-current={isActive(item.href) ? "page" : undefined}
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>

      <a class="site-header__mobile-cta" href="/contact/#reach-quavar">Request a Proposal</a>
    </nav>
  </div>
</header>

<script>
  const header = document.querySelector("[data-site-header]");
  const menuButton = document.querySelector("[data-menu-button]");
  const mobileNav = document.querySelector("[data-mobile-nav]");

  if (header) {
    const updateHeader = () => {
      header.classList.toggle("site-header--scrolled", window.scrollY > 24);
    };

    updateHeader();
    window.addEventListener("scroll", updateHeader, { passive: true });
  }

  if (menuButton && mobileNav) {
    const closeMenu = () => {
      header?.classList.remove("site-header--menu-open");
      menuButton.setAttribute("aria-expanded", "false");
      mobileNav.setAttribute("hidden", "");
    };

    const openMenu = () => {
      header?.classList.add("site-header--menu-open");
      menuButton.setAttribute("aria-expanded", "true");
      mobileNav.removeAttribute("hidden");
    };

    menuButton.addEventListener("click", () => {
      const isOpen = menuButton.getAttribute("aria-expanded") === "true";
      isOpen ? closeMenu() : openMenu();
    });

    mobileNav.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", closeMenu);
    });

    window.addEventListener("keydown", (event) => {
      if (event.key === "Escape") closeMenu();
    });

    window.addEventListener("resize", () => {
      if (window.innerWidth > 920) closeMenu();
    });
  }
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(255, 255, 255, 0.94);
    border-bottom: 1px solid rgba(0, 30, 61, 0.06);
    transition:
      background var(--transition-medium),
      border-color var(--transition-medium),
      box-shadow var(--transition-medium);
  }

  .site-header--scrolled,
  .site-header--menu-open {
    background: rgba(255, 255, 255, 0.88);
    border-bottom-color: rgba(0, 30, 61, 0.10);
    box-shadow: 0 18px 40px rgba(0, 30, 61, 0.055);
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
  }

  .site-header__inner {
    min-height: 76px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 40px;
    transition: min-height var(--transition-medium);
  }

  .site-header--scrolled .site-header__inner {
    min-height: 68px;
  }

  .site-header__logo {
    display: inline-flex;
    align-items: center;
    flex-shrink: 0;
  }

  .site-header__logo img {
    display: block;
    width: 168px;
    height: auto;
    transition:
      width var(--transition-medium),
      opacity var(--transition-medium);
  }

  .site-header--scrolled .site-header__logo img {
    width: 156px;
  }

  .site-header__nav {
    margin-left: auto;
  }

  .site-header__nav ul,
  .site-header__mobile ul {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .site-header__nav ul {
    display: flex;
    align-items: center;
    gap: 28px;
  }

  .site-header__nav a {
    position: relative;
    display: inline-flex;
    align-items: center;
    padding: 12px 0;
    font-size: 12px;
    font-weight: 700;
    line-height: 1;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    color: var(--color-navy);
    transition: color var(--transition-fast);
  }

  .site-header__nav a::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: 4px;
    width: 100%;
    height: 1px;
    background: var(--color-teal);
    transform: scaleX(0);
    transform-origin: right;
    transition: transform var(--transition-fast);
  }

  .site-header__nav a:hover::after,
  .site-header__nav a.is-active::after {
    transform: scaleX(1);
    transform-origin: left;
  }

  .site-header__nav a.is-active {
    color: var(--color-navy);
  }

  .site-header__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 40px;
    padding: 0 18px;
    border: 1px solid rgba(0, 30, 61, 0.18);
    border-radius: 999px;
    font-size: 11px;
    font-weight: 700;
    line-height: 1;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    color: var(--color-navy);
    background: rgba(255, 255, 255, 0.68);
    transition:
      background var(--transition-fast),
      border-color var(--transition-fast),
      color var(--transition-fast),
      transform var(--transition-fast);
  }

  .site-header__cta:hover {
    background: var(--color-navy);
    border-color: var(--color-navy);
    color: var(--color-white);
    transform: translateY(-1px);
  }

  .site-header__menu-button {
    display: none;
    width: 44px;
    height: 44px;
    padding: 0;
    border: 1px solid rgba(0, 30, 61, 0.14);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.72);
    color: var(--color-navy);
    cursor: pointer;
  }

  .site-header__menu-button span {
    display: block;
    width: 18px;
    height: 1.5px;
    margin: 0 auto;
    background: currentColor;
    transition:
      transform var(--transition-fast),
      opacity var(--transition-fast);
  }

  .site-header__menu-button span + span {
    margin-top: 6px;
  }

  .site-header__menu-button[aria-expanded="true"] span:first-child {
    transform: translateY(3.75px) rotate(45deg);
  }

  .site-header__menu-button[aria-expanded="true"] span:last-child {
    transform: translateY(-3.75px) rotate(-45deg);
  }

  .site-header__mobile {
    border-top: 1px solid rgba(0, 30, 61, 0.07);
    background: rgba(255, 255, 255, 0.96);
  }

  .site-header__mobile[hidden] {
    display: none;
  }

  .site-header__mobile nav {
    padding-top: 24px;
    padding-bottom: 28px;
  }

  .site-header__mobile ul {
    display: grid;
    gap: 4px;
  }

  .site-header__mobile a {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 0;
    border-bottom: 1px solid rgba(0, 30, 61, 0.07);
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-navy);
  }

  .site-header__mobile a::after {
    content: "→";
    color: var(--color-teal);
    font-size: 14px;
  }

  .site-header__mobile a.is-active {
    color: var(--color-teal);
  }

  .site-header__mobile .site-header__mobile-cta {
    justify-content: center;
    margin-top: 24px;
    padding: 16px 20px;
    border: 1px solid var(--color-navy);
    border-radius: 999px;
    background: var(--color-navy);
    color: var(--color-white);
  }

  .site-header__mobile .site-header__mobile-cta::after {
    display: none;
  }

  @media (max-width: 1040px) {
    .site-header__nav ul {
      gap: 22px;
    }

    .site-header__cta {
      display: none;
    }
  }

  @media (max-width: 920px) {
    .site-header__inner {
      min-height: 72px;
      gap: 24px;
    }

    .site-header--scrolled .site-header__inner {
      min-height: 68px;
    }

    .site-header__logo img,
    .site-header--scrolled .site-header__logo img {
      width: 166px;
    }

    .site-header__nav {
      display: none;
    }

    .site-header__menu-button {
      display: inline-grid;
      place-items: center;
    }
  }

  @media (max-width: 480px) {
    .site-header__logo img,
    .site-header--scrolled .site-header__logo img {
      width: 156px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .site-header,
    .site-header__inner,
    .site-header__logo img,
    .site-header__nav a,
    .site-header__nav a::after,
    .site-header__cta,
    .site-header__menu-button span {
      transition: none;
    }
  }
</style>
