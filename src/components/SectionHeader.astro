---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  align?: 'left' | 'center';
  theme?: 'light' | 'dark';
  size?: 'standard' | 'large';
  id?: string;
  class?: string;
}

const {
  eyebrow,
  title,
  description,
  align = 'left',
  theme = 'light',
  size = 'standard',
  id,
  class: className = '',
} = Astro.props;

const classes = [
  'section-header',
  `section-header--${align}`,
  `section-header--${theme}`,
  `section-header--${size}`,
  className,
]
  .filter(Boolean)
  .join(' ');
---

<div class={classes}>
  {eyebrow && <p class="section-header__eyebrow">{eyebrow}</p>}

  <h2 id={id} class="section-header__title">{title}</h2>

  {description && <p class="section-header__description">{description}</p>}
</div>

<style>
  .section-header {
    position: relative;
    max-width: 820px;
  }

  .section-header--center {
    margin-right: auto;
    margin-left: auto;
    text-align: center;
  }

  .section-header__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    margin: 0 0 20px;
    color: var(--color-teal);
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.18em;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .section-header__eyebrow::before {
    content: '';
    display: inline-block;
    width: 34px;
    height: 1px;
    background: currentColor;
  }

  .section-header--center .section-header__eyebrow::after {
    content: '';
    display: inline-block;
    width: 34px;
    height: 1px;
    background: currentColor;
  }

  .section-header__title {
    margin: 0;
    max-width: 820px;
    color: var(--color-navy);
    font-family: var(--font-heading);
    font-size: clamp(2.15rem, 4vw, 3.2rem);
    font-weight: 600;
    letter-spacing: -0.05em;
    line-height: 1.04;
  }

  .section-header--large .section-header__title {
    max-width: 920px;
    font-size: clamp(2.65rem, 5.2vw, 4.4rem);
    line-height: 1.01;
  }

  .section-header--center .section-header__title {
    margin-right: auto;
    margin-left: auto;
  }

  .section-header__description {
    margin: 26px 0 0;
    max-width: 700px;
    color: var(--color-slate);
    font-size: clamp(1.1rem, 1.4vw, 1.28rem);
    line-height: 1.68;
    text-wrap: pretty;
  }

  .section-header--center .section-header__description {
    margin-right: auto;
    margin-left: auto;
  }

  .section-header--dark .section-header__eyebrow,
  .section-header--dark .section-header__title,
  .section-header--dark .section-header__description {
    color: var(--color-white);
  }

  .section-header--dark .section-header__eyebrow {
    color: var(--color-teal);
  }

  .section-header--dark .section-header__description {
    opacity: 0.78;
  }

  @media (max-width: 760px) {
    .section-header {
      max-width: none;
    }

    .section-header__eyebrow {
      margin-bottom: 16px;
      font-size: 10.5px;
      letter-spacing: 0.16em;
    }

    .section-header__eyebrow::before,
    .section-header--center .section-header__eyebrow::after {
      width: 24px;
    }

    .section-header__description {
      margin-top: 20px;
    }
  }
</style>
