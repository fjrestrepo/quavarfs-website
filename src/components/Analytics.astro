---
const gaId = import.meta.env.PUBLIC_GA_MEASUREMENT_ID;
const clarityId = import.meta.env.PUBLIC_CLARITY_PROJECT_ID;
---

{
  gaId && (
    <>
      <script async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}></script>

      <script define:vars={{ gaId }} is:inline>
        window.dataLayer = window.dataLayer || [];
        window.gtag = window.gtag || function gtag(){window.dataLayer.push(arguments);};
        window.gtag('js', new Date());
        window.gtag('config', gaId);
      </script>
    </>
  )
}

{
  clarityId && (
    <script define:vars={{ clarityId }} is:inline>
      (function(c,l,a,r,i,t,y){
        c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
        t=l.createElement(r);
        t.async=1;
        t.src="https://www.clarity.ms/tag/"+i;
        y=l.getElementsByTagName(r)[0];
        y.parentNode.insertBefore(t,y);
      })(window, document, "clarity", "script", clarityId);
    </script>
  )
}

<script is:inline>
  window.trackQuavarEvent = function trackQuavarEvent(eventName, params = {}) {
    const payload = {
      page_path: window.location.pathname,
      page_title: document.title,
      ...params,
    };

    if (typeof window.gtag === "function") {
      window.gtag("event", eventName, payload);
    }

    if (typeof window.clarity === "function") {
      window.clarity("event", eventName);
    }
  };
</script>
